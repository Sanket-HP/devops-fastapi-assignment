# Application Configuration
ENV=production
APP_NAME="Production FastAPI Backend"
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_db_password_change_me
POSTGRES_DB=app_db
