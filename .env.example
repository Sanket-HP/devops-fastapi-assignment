POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=secure_redis_password_change_me

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=logs
